# Django
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY=your-secret-key-here

# Database
DB_NAME=healthcare_ims
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
