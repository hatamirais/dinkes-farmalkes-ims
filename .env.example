# Django
# DJANGO_SECRET_KEY is REQUIRED. Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secret-key-here

# Toggle debug mode (default: False). MUST set to True for local development
# so that runserver serves static files (CSS/JS).
DEBUG=True

# Database
DB_NAME=healthcare_ims
DB_USER=postgres
DB_PASSWORD=change-this-password
DB_HOST=localhost
DB_PORT=5432

# Allowed Hosts (comma-separated, required in production)
ALLOWED_HOSTS=localhost,127.0.0.1

# CSRF trusted origins (comma-separated, required when behind a reverse proxy or custom domain)
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# Email backend (defaults to console in development)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Private uploaded-file storage used for receiving document attachments.
# Keep this path outside any publicly served media directory in production.
PRIVATE_MEDIA_ROOT=

# Caching is configured to use Django's local memory cache (LocMemCache) in-process.
# No external cache URL setting is needed for local setup.

# Sensitive POST rate limits
RATELIMIT_FAIL_OPEN=True
USER_BULK_ACTION_RATE_LIMIT=10/m
USER_MUTATION_RATE_LIMIT=20/m
USER_PASSWORD_RESET_RATE_LIMIT=5/m
PASSWORD_CHANGE_RATE_LIMIT=5/m
PUSKESMAS_SBBK_MUTATION_RATE_LIMIT=20/m

# Maximum number of POST fields allowed per request.
# Increase if LPLPO or other wide forms exceed Django's default limit.
DATA_UPLOAD_MAX_NUMBER_FIELDS=10000

# Feature Flags / compatibility settings
# FEATURE_ALLOCATION_UI_ENABLED is still loaded into Django settings and tests,
# but current runtime Allocation access is governed by permissions/module scope.
FEATURE_ALLOCATION_UI_ENABLED=True

# Security (production only)
SECURE_SSL_REDIRECT=False
