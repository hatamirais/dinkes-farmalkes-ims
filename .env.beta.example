# Beta / server deployment template for Healthcare IMS
#
# Use this as the starting point for a single-client beta deployment.
# Copy to a private runtime env file on the target machine, for example:
# - `.env.demo`
# - `.env.beta`
# - `.env`
#
# Do not commit the real filled-in env file.

# Django
DJANGO_SETTINGS_MODULE=config.settings
DJANGO_SECRET_KEY=replace-with-a-generated-secret-key
DEBUG=False
DJANGO_LOG_LEVEL=WARNING

# Database
DB_NAME=healthcare_ims
DB_USER=postgres
DB_PASSWORD=replace-with-a-strong-password
DB_HOST=postgres
DB_PORT=5432
DB_WAIT_TIMEOUT=60

# Web / host routing
# Replace with the real beta domain once assigned.
ALLOWED_HOSTS=your-beta-domain
CSRF_TRUSTED_ORIGINS=https://your-beta-domain
SECURE_SSL_REDIRECT=True

# Uploaded file handling
# Keep this path outside any publicly served media directory.
PRIVATE_MEDIA_ROOT=/app/backend/private_media

# Gunicorn
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Sensitive POST rate limits
RATELIMIT_FAIL_OPEN=True
USER_BULK_ACTION_RATE_LIMIT=10/m
USER_MUTATION_RATE_LIMIT=20/m
USER_PASSWORD_RESET_RATE_LIMIT=5/m
PASSWORD_CHANGE_RATE_LIMIT=5/m

# Maximum number of POST fields allowed per request.
DATA_UPLOAD_MAX_NUMBER_FIELDS=10000

# Feature flags / compatibility settings
FEATURE_ALLOCATION_UI_ENABLED=True

